root = true

[*]
end_of_line = lf
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
# Do NOT trim trailing whitespace in markdown: two trailing spaces are the
# CommonMark spec syntax for a hard line break (<br>). Trimming them would
# collapse intentional line breaks into run-on paragraphs.
trim_trailing_whitespace = false
indent_size = 2

[*.sh]
indent_style = space
indent_size = 4

[*.{js,mjs,cjs}]
indent_style = space
indent_size = 2

[*.{json,yaml,yml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
